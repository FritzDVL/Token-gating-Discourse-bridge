# ─────────── Alchemy (chain RPC + WebSocket) ───────────
# Required. Get it free at https://alchemy.com (no credit card).
# Create app → Ethereum / Mainnet → copy the key from the app's HTTPS URL:
#   https://eth-mainnet.g.alchemy.com/v2/<THIS_PART>
ALCHEMY_API_KEY=replace-me

# ─────────── NFT contract being gated ───────────
# Full 42-char address.
NFT_CONTRACT_ADDRESS=0xa3AFreplaceWithFullAddress0000000000008ce3
NFT_CHAIN_ID=1

# ─────────── Discourse HTTP API ───────────
DISCOURSE_BASE_URL=https://forum.societyprotocol.io
# Granular API key, user 'system', scopes:
#   groups#add_members, groups#remove_member, groups#show, users#show
DISCOURSE_API_KEY=replace-me
DISCOURSE_API_USERNAME=system

# ─────────── Discourse Postgres (read-only role) ───────────
DISCOURSE_DB_HOST=127.0.0.1
DISCOURSE_DB_PORT=5432
DISCOURSE_DB_NAME=discourse
DISCOURSE_DB_USER=tg_bridge_ro
DISCOURSE_DB_PASSWORD=replace-me

# ─────────── Reconciler (safety-net polling) ───────────
RECONCILE_ENABLED=true
RECONCILE_INTERVAL_MINUTES=60
RECONCILE_ON_BOOT=true
RECONCILE_CONCURRENCY=4

# ─────────── Chain listener (real-time WebSocket) ───────────
CHAIN_LISTENER_ENABLED=true
CHAIN_LISTENER_RECONNECT_MIN_MS=2000
CHAIN_LISTENER_RECONNECT_MAX_MS=60000

# ─────────── Service ───────────
PORT=3001
ADMIN_TOKEN=generate-a-long-random-string
LOG_LEVEL=info
